# Board identification
CONFIG_BOARD_EFOGTECH_0_VER_MAJOR=100
CONFIG_BOARD_EFOGTECH_0_VER_MINOR=4
CONFIG_BOARD_EFOGTECH_0_VER_PATCH=22
CONFIG_BOARD_EFOGTECH_TRBL_52833=y
CONFIG_SOC_SERIES_NRF52X=y
CONFIG_SOC_NRF52833_QIAA=y
CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=n
CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_BUILD_OUTPUT_UF2=y

# Storage
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y
CONFIG_CLOCK_CONTROL_NRF=y
CONFIG_CLOCK_CONTROL_NRF_K32SRC_RC=y

# Split peripheral
CONFIG_ZMK_SPLIT=y
CONFIG_ZMK_SPLIT_BLE=y
CONFIG_ZMK_BLE=y
CONFIG_ZMK_USB=n

# Pointing
CONFIG_ZMK_POINTING=y
CONFIG_SPI=y
CONFIG_SPI_ASYNC=y
CONFIG_INPUT=y
CONFIG_GPIO=y
CONFIG_PINCTRL=y
CONFIG_PAW3395=y
CONFIG_INPUT_THREAD_STACK_SIZE=1024
CONFIG_ZMK_POINTER_2S_MIXER=y
CONFIG_ZMK_INPUT_PROCESSOR_REPORT_RATE_LIMIT=y
CONFIG_ZMK_INPUT_PROCESSOR_REPORT_RATE_LIMIT_DEFAULT=2
CONFIG_ZMK_AXIS_CLAMPER=y

# Encoders
CONFIG_EC11=y
CONFIG_EC11_ISH=y

# BLE
CONFIG_ZMK_BLE_EXPERIMENTAL_CONN=y
CONFIG_ZMK_BLE_EXPERIMENTAL_SEC=y
CONFIG_ZMK_BLE_EXPERIMENTAL_FEATURES=y
CONFIG_ZMK_BLE_PASSKEY_ENTRY=n
CONFIG_BT_CTLR_TX_PWR_PLUS_8=y
CONFIG_BT_CTLR_CONN_RSSI=y
CONFIG_BT_CTLR_TX_PWR_DYNAMIC_CONTROL=y
CONFIG_BT_CTLR_PHY_2M=y
CONFIG_BT_PERIPHERAL_PREF_MAX_INT=6
CONFIG_BT_TPS=y
CONFIG_BT_GATT_ENFORCE_SUBSCRIPTION=y
CONFIG_BT_MAX_CONN=5
CONFIG_BT_MAX_PAIRED=5
CONFIG_ZMK_BLE_MOUSE_REPORT_QUEUE_SIZE=1
CONFIG_ZMK_BLE_THREAD_STACK_SIZE=1360
CONFIG_ZMK_BLE_THREAD_PRIORITY=2
CONFIG_BT_L2CAP_TX_MTU=65
CONFIG_BT_L2CAP_TX_FRAG_COUNT=3
CONFIG_BT_BUF_ACL_RX_SIZE=69
CONFIG_BT_BUF_ACL_TX_SIZE=72

# Mixer tuning
CONFIG_POINTER_2S_MIXER_REMAINDER_TTL=16
CONFIG_POINTER_2S_MIXER_DIRECTION_FILTER_EN=y
CONFIG_POINTER_2S_MIXER_34_FILTER_EN=y
CONFIG_POINTER_2S_MIXER_SENS_DRIFT_CORRECTION=1
CONFIG_POINTER_2S_MIXER_TWIST_REMAINDER_TTL=100
CONFIG_POINTER_2S_MIXER_FEEDBACK_MAX_CONTINUOUS=65
CONFIG_POINTER_2S_MIXER_FEEDBACK_COOLDOWN=160
CONFIG_POINTER_2S_MIXER_SYNC_WINDOW_MS=6
CONFIG_POINTER_2S_MIXER_FEEDBACK_EN=y
CONFIG_POINTER_2S_MIXER_SCROLL_DISABLES_POINTER=n
CONFIG_POINTER_2S_MIXER_POINTER_AFTER_SCROLL_ACTIVATION=160
CONFIG_POINTER_2S_MIXER_LAZY_INIT=n
CONFIG_POINTER_2S_MIXER_DIRECTION_FILTER_TTL=80
CONFIG_POINTER_2S_MIXER_TWIST_FILTER_TTL=65
CONFIG_POINTER_2S_MIXER_TWIST_FILTER_DEBOUNCE=35
CONFIG_POINTER_2S_MIXER_SIGNIFICANT_MOVEMENT_MUL=15
CONFIG_POINTER_2S_MIXER_DELTA_Y_OVER_TRANS_MAG_MUL=4
CONFIG_POINTER_2S_MIXER_SMA_EN=y

# Debounce
CONFIG_ZMK_KSCAN_DEBOUNCE_PRESS_MS=0
CONFIG_ZMK_KSCAN_DEBOUNCE_RELEASE_MS=0

# Power management
CONFIG_PM_DEVICE=y
CONFIG_PM_DEVICE_RUNTIME=y
CONFIG_PM_DEVICE_RUNTIME_EXCLUSIVE=n

# Build optimization
CONFIG_SIZE_OPTIMIZATIONS=n
CONFIG_SPEED_OPTIMIZATIONS=y
CONFIG_BUILD_OUTPUT_STRIPPED=y
CONFIG_DEBUG_INFO=n
CONFIG_ASSERT=n
CONFIG_BOOT_BANNER=n
CONFIG_SPI_NRFX_RAM_BUFFER_SIZE=24

# UART (needed for board init code)
CONFIG_SERIAL=y

# Settings save
CONFIG_ZMK_SETTINGS_SAVE_DEBOUNCE=2500

# Keyboard name
CONFIG_ZMK_KEYBOARD_NAME="Endgame"

# Runtime config (needed by pointer-2s-mixer)
CONFIG_ZMK_RUNTIME_CONFIG=y
